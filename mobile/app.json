{
  "expo": {
    "name": "I Wanna Cook",
    "slug": "i-wanna-cook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "backgroundColor": "#0f1117",
      "edgeToEdgeEnabled": true,
      "package": "com.alwmedia.iwannacook"
    },
    "extra": {
      "apiBaseUrl": "https://main.d1fv3pyedpdjxn.amplifyapp.com"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-speech-recognition",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow I Wanna Cook to access your photos to identify ingredients.",
          "cameraPermission": "Allow I Wanna Cook to use your camera to photograph ingredients."
        }
      ]
    ]
  }
}
